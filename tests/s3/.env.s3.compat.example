# Copy this file to tests/s3/.env.s3.compat.local and fill values.
# Run with: pnpm exec dotenv -e tests/s3/.env.s3.compat.local -- pnpm test:s3:compat

S3_TEST_ENDPOINT=https://storage.wpsadi.dev
S3_TEST_REGION=auto
S3_TEST_BUCKET=test
S3_TEST_ACCESS_KEY_ID=replace-with-access-key-id
S3_TEST_SECRET_ACCESS_KEY=replace-with-secret-access-key
S3_TEST_DUMMY_FILE_PATH=tests/s3/fixtures/dummy-upload.txt
S3_TEST_SD_COMPARTMENT_PREFIX=sd
S3_TEST_ENABLE_MULTIPART=true
