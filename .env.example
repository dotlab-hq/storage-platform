# Database URL for PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/database"

# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-here

# GitHub OAuth configuration
_GITHUB_CLIENT_ID=your-github-client-id
_GITHUB_CLIENT_SECRET=your-github-client-secret

# S3/Storage configuration
S3_REGION=eu-central-1
S3_ENDPOINT=https://your-storage-endpoint.supabase.co/storage/v1/s3
S3_BUCKET_NAME=dot-storage
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# S3 compatibility Playwright test configuration
S3_TEST_ENDPOINT=https://storage.wpsadi.dev/api/storage/s3
S3_TEST_REGION=auto
S3_TEST_BUCKET=test
S3_TEST_ACCESS_KEY_ID=your-test-access-key-id
S3_TEST_SECRET_ACCESS_KEY=your-test-secret-access-key
S3_TEST_DUMMY_FILE_PATH=tests/s3/fixtures/dummy-upload.txt
S3_TEST_SD_COMPARTMENT_PREFIX=sd
S3_TEST_ENABLE_MULTIPART=true

# Encryption key for provider credentials stored in DB
STORAGE_PROVIDER_ENCRYPTION_KEY=your-long-random-encryption-secret
