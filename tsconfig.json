{
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "worker-configuration.d.ts",
    "drizzle.config.ts",
    "vite.config.ts",
    "nitro.config.ts",
    "playwright.s3.config.ts"
  ],
  "exclude": [
    "my-tanstack-start-app",
    "node_modules",
    "playwright-report",
    "test-results",
    ".agents",
    ".github"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["./worker-configuration.d.ts", "node", "vite/client"],
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
