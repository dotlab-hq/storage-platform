{
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "worker-configuration.d.ts",
    "drizzle.config.ts",
    "vite.config.ts",
    "nitro.config.ts",
    "playwright.s3.config.ts"
  ],
  "exclude": [
    "my-tanstack-start-app",
    "node_modules",
    "playwright-report",
    "test-results",
    ".agents",
    ".github",
    "src/lib/agent/orcheration/**",
    "src/lib/agent/orchestration/graph-v2.ts",
    "src/lib/agent/orchestration/supervisor-graph-clean.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
      "WebWorker"
    ],
    "types": [
      "./worker-configuration.d.ts",
      "node",
      "vite/client"
    ],
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}