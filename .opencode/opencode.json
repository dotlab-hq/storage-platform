    //         "bunx",
    //         "-y",
    //         "mcp-bun@latest"
    //     ],
    //     "environment": {
    //         "DISABLE_NOTIFICATIONS": "true"
    //     }
    // },
    "21st_dev": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@21st-dev/magic@latest",
        "--api-key",
        "${21ST_DEV_API_KEY}"
      ],
      "environment": {
        "21ST_DEV_API_KEY": "07a337844845f18c59bc59e27eed9c36726fcbcee41a04edfe6172760ccaf651"
      }
    }
  },
  "plugin": [".opencode/plugins/graphify.js"]
}
