{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "instructions": ["overall architecture.md", "Agents.md", "plans/**"],
  "default_agent": "plan",
  "share": "manual",
  "formatter": {},
  "mcp": {
    "better-auth": {
      "type": "remote",
      "url": "https://mcp.better-auth.com/mcp"
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "aceternityui": {
      "command": ["npx", "aceternityui-mcp"],
      "type": "local"
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "type": "local"
    },
